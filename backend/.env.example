# Database URL
DATABASE_URL=sqlite:///./sql_app.db

# JWT Token Security Configurations
SECRET_KEY=super_secret_ats_key_for_development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Google OAuth Credentials
# Retrieve from Google Cloud Console -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth Credentials
# Retrieve from GitHub Developer Settings -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign In Credentials
# Apple Client ID (Services ID)
APPLE_CLIENT_ID=
